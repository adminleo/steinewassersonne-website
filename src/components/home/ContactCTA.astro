---
import { useTranslations } from '../../i18n/utils';
import type { Lang } from '../../i18n/languages';
import { routeMap } from '../../i18n/languages';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="section-padding bg-brand-teal-500 text-white">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl sm:text-4xl font-bold mb-4">
      {t('cta.title')}
    </h2>
    <p class="text-brand-cream-200 mb-8 max-w-2xl mx-auto">
      {t('cta.subtitle')}
    </p>
    <a href={routeMap.contact[lang]} class="btn-primary bg-white text-brand-teal-900 hover:bg-brand-cream-200">
      {t('cta.button')}
    </a>
  </div>
</section>
