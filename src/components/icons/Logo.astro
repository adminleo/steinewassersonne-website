---
interface Props {
  class?: string;
  width?: number;
  height?: number;
  variant?: 'full' | 'icon';
}

const { class: className, width, height, variant = 'full' } = Astro.props;
const w = width ?? (variant === 'full' ? 220 : 50);
const h = height ?? (variant === 'full' ? 50 : 50);
---

{variant === 'full' ? (
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 220 50"
    width={w}
    height={h}
    class={className}
    role="img"
    aria-label="Steinewassersonne Logo"
  >
    <!-- Icon: Sonne (Kreis) + Wasser (Welle) + Steine (Linien) -->
    <g class="text-brand-teal-500" fill="none" stroke="currentColor">
      <!-- Sonne - Kreis oben -->
      <circle cx="22" cy="14" r="11" stroke-width="3" />
      <!-- Wasser - Welle, die den Kreis unten verbindet -->
      <path d="M11,14 Q11,28 22,28 Q33,28 33,20" stroke-width="3" fill="none" stroke-linecap="round" />
      <!-- Steine - Horizontale Linien -->
      <path d="M6,34 Q22,30 38,34" stroke-width="2.5" stroke-linecap="round" />
      <path d="M10,39 Q22,36 34,39" stroke-width="2" stroke-linecap="round" />
      <path d="M14,43 Q22,41 30,43" stroke-width="1.5" stroke-linecap="round" />
    </g>
    <!-- Firmenname -->
    <text x="50" y="23" font-family="'Playfair Display', Georgia, serif" font-size="15" font-weight="700" fill="currentColor" class="text-brand-teal-900">
      STEINEWASSERSONNE
    </text>
    <text x="50" y="38" font-family="'Inter', system-ui, sans-serif" font-size="7" letter-spacing="1.5" fill="currentColor" class="text-brand-teal-600">
      LANDSCHAFTSGESTALTUNG &amp; BAUWERKSBEGRÜNUNG
    </text>
  </svg>
) : (
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 44 50"
    width={w}
    height={h}
    class={className}
    role="img"
    aria-label="Steinewassersonne"
  >
    <g class="text-brand-teal-500" fill="none" stroke="currentColor">
      <circle cx="22" cy="14" r="11" stroke-width="3" />
      <path d="M11,14 Q11,28 22,28 Q33,28 33,20" stroke-width="3" fill="none" stroke-linecap="round" />
      <path d="M6,34 Q22,30 38,34" stroke-width="2.5" stroke-linecap="round" />
      <path d="M10,39 Q22,36 34,39" stroke-width="2" stroke-linecap="round" />
      <path d="M14,43 Q22,41 30,43" stroke-width="1.5" stroke-linecap="round" />
    </g>
  </svg>
)}
