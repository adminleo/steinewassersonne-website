---
import { useTranslations } from '../../i18n/utils';
import type { Lang } from '../../i18n/languages';

interface Props {
  location: string;
  year: number;
  scope: string;
  category: string;
  lang: Lang;
}

const { location, year, scope, category, lang } = Astro.props;
const t = useTranslations(lang);
---

<div class="bg-brand-cream-100 rounded-xl p-6 space-y-4 sticky top-24">
  <div>
    <span class="text-xs font-medium uppercase tracking-wider text-brand-teal-500">{t('projects.location')}</span>
    <p class="text-sm font-medium text-brand-teal-900 mt-1">{location}</p>
  </div>
  <div>
    <span class="text-xs font-medium uppercase tracking-wider text-brand-teal-500">{t('projects.year')}</span>
    <p class="text-sm font-medium text-brand-teal-900 mt-1">{year}</p>
  </div>
  <div>
    <span class="text-xs font-medium uppercase tracking-wider text-brand-teal-500">{t('projects.scope')}</span>
    <p class="text-sm font-medium text-brand-teal-900 mt-1">{scope}</p>
  </div>
  <div class="pt-2 border-t border-brand-cream-300">
    <span class="inline-block px-3 py-1 text-xs font-medium rounded-full bg-brand-teal-100 text-brand-teal-700">
      {t(`projects.filter.${category}` as any) || category}
    </span>
  </div>
</div>
