---
import { useTranslations } from '../../i18n/utils';
import type { Lang } from '../../i18n/languages';

interface Props {
  categories: string[];
  lang: Lang;
}

const { categories, lang } = Astro.props;
const t = useTranslations(lang);
---

<div class="flex flex-wrap gap-2" id="project-filters">
  <button
    class="filter-btn active px-4 py-2 text-sm font-medium rounded-full bg-brand-teal-500 text-white transition-colors cursor-pointer"
    data-filter="all"
  >
    {t('projects.all')}
  </button>
  {categories.map((cat) => (
    <button
      class="filter-btn px-4 py-2 text-sm font-medium rounded-full bg-brand-cream-200 text-brand-teal-700 hover:bg-brand-teal-500 hover:text-white transition-colors cursor-pointer"
      data-filter={cat}
    >
      {t(`projects.filter.${cat}` as any) || cat}
    </button>
  ))}
</div>

<script>
  const buttons = document.querySelectorAll('.filter-btn');
  const items = document.querySelectorAll('[data-category]');

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = (btn as HTMLElement).dataset.filter;

      buttons.forEach((b) => {
        b.classList.remove('active', 'bg-brand-teal-500', 'text-white');
        b.classList.add('bg-brand-cream-200', 'text-brand-teal-700');
      });
      btn.classList.add('active', 'bg-brand-teal-500', 'text-white');
      btn.classList.remove('bg-brand-cream-200', 'text-brand-teal-700');

      items.forEach((item) => {
        const el = item as HTMLElement;
        if (filter === 'all' || el.dataset.category === filter) {
          el.style.display = '';
        } else {
          el.style.display = 'none';
        }
      });
    });
  });
</script>
