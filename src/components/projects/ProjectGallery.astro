---
interface Props {
  images: string[];
  title: string;
}

const { images, title } = Astro.props;
---

<section class="mt-16">
  <h2 class="font-display text-2xl font-semibold text-brand-teal-900 mb-6">Galerie</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    {images.map((image, i) => (
      <div class="aspect-[4/3] bg-brand-cream-200 rounded-lg overflow-hidden">
        <img
          src={image}
          alt={`${title} — Bild ${i + 1}`}
          class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
          loading="lazy"
          onerror="this.parentElement.classList.add('flex','items-center','justify-center'); this.style.display='none'; this.parentElement.innerHTML='<span class=\'text-brand-teal-400 text-sm\'>Bild ' + (parseInt(this.alt.match(/\\d+/)?.[0] || '1')) + '</span>'"
        />
      </div>
    ))}
  </div>
</section>
