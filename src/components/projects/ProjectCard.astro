---
interface Props {
  title: string;
  description: string;
  category: string;
  heroImage: string;
  href: string;
  location: string;
  year: number;
}

const { title, description, category, heroImage, href, location, year } = Astro.props;

const categoryLabels: Record<string, string> = {
  'landscape': 'Landschaft',
  'roof-greening': 'Dachbegrünung',
  'facade-greening': 'Fassade',
  'garden-design': 'Garten',
  'planning': 'Planung',
};
---

<a href={href} class="group block bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow">
  <div class="aspect-[4/3] overflow-hidden bg-brand-cream-200">
    <img
      src={heroImage}
      alt={title}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      loading="lazy"
      onerror="this.style.display='none'"
    />
  </div>
  <div class="p-5">
    <span class="text-xs font-medium uppercase tracking-wider text-brand-teal-500 mb-2 block">
      {categoryLabels[category] || category}
    </span>
    <h3 class="font-display text-lg font-semibold text-brand-teal-900 mb-2 group-hover:text-brand-teal-600 transition-colors">
      {title}
    </h3>
    <p class="text-sm text-brand-teal-700/70 line-clamp-2">{description}</p>
    <div class="mt-3 flex items-center gap-3 text-xs text-brand-teal-600">
      <span>{location}</span>
      <span class="text-brand-cream-400">|</span>
      <span>{year}</span>
    </div>
  </div>
</a>
